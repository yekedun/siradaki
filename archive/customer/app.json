{
  "expo": {
    "name": "Berber Müşteri",
    "slug": "berber-musteri",
    "version": "1.0.0",
    "scheme": "berbermusterapp",
    "orientation": "portrait",
    "icon": "../mobile/assets/icon.png",
    "splash": {
      "image": "../mobile/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8FAFC"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.berberapp.musteri"
    },
    "android": {
      "package": "com.berberapp.musteri",
      "adaptiveIcon": {
        "foregroundImage": "../mobile/assets/adaptive-icon.png",
        "backgroundColor": "#F8FAFC"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
