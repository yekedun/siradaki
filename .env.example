# ─────────────────────────────────────────────
# Supabase — https://supabase.com/dashboard/project/_/settings/api
# ─────────────────────────────────────────────

# Proje URL (public)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Anon/public key (public) — sadece RLS-korumalı okuma
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role key — SADECE sunucu tarafında, edge functions içinde
# Asla client'a gönderme / commit etme
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─────────────────────────────────────────────
# Upstash Redis — https://console.upstash.com
# IP bazlı rate limiting için (book-appointment edge function)
# ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxxxxxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
