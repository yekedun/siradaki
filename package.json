{
  "name": "berber-randevu",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "type-check": "turbo typecheck",
    "lint": "turbo lint",
    "backend:proof": "powershell -ExecutionPolicy Bypass -File scripts/scheduling-proof.ps1",
    "backend:proof:fast": "powershell -ExecutionPolicy Bypass -File scripts/scheduling-proof.ps1 -SkipReset",
    "backend:remote-smoke": "powershell -ExecutionPolicy Bypass -File scripts/scheduling-remote-smoke.ps1",
    "backend:remote-smoke:skip-push": "powershell -ExecutionPolicy Bypass -File scripts/scheduling-remote-smoke.ps1 -SkipPush",
    "db:sync": "bash supabase/functions/_sync-types.sh",
    "db:check": "node -e \"const fs=require('fs');const a=fs.readFileSync('packages/db/src/database.types.ts','utf8');const b=fs.readFileSync('supabase/functions/_shared/database.types.ts','utf8');if(a!==b){console.error('database.types out of sync - run pnpm db:sync');process.exit(1)}\"",
    "audit:map": "tsx scripts/audit/build-map.ts",
    "audit:probe": "tsx scripts/audit/probe.ts",
    "audit:edge-smoke": "tsx scripts/audit/edge-smoke.ts",
    "e2e:booking": "tsx scripts/e2e/booking-flow.ts",
    "e2e:concurrent-booking": "tsx scripts/e2e/concurrent-booking.ts",
    "audit:e2e": "pnpm audit:edge-smoke && pnpm e2e:booking && pnpm e2e:concurrent-booking",
    "test:backend": "pnpm audit:e2e && pnpm db:check",
    "audit": "pnpm audit:map && pnpm audit:probe && pnpm audit:edge-smoke"
  },
  "devDependencies": {
    "tsx": "^4.22.3",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
