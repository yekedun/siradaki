# Dependencies
node_modules/
.pnpm-store/

# Lockfiles — monorepo uses pnpm-lock.yaml at root; per-package npm lockfiles are noise
apps/*/package-lock.json
packages/*/package-lock.json

# Environment variables — NEVER commit
.env
.env.local
.env.*.local
.env.production

# Build outputs
dist/
build/
.next/
*.tsbuildinfo

# Turbo cache
.turbo/

# Supabase local dev
supabase/.branches/
supabase/.temp/

# Sensitive SQL dumps — never commit
*_backup.sql
*.dump.sql

# Expo / React Native
.expo/
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*

# Agent / tooling noise
.agent/*.log
.codebase-map.txt
.superpowers/
.ai/
reports/
tmp-mobile-metro-fixture*.log

# Generated / ephemeral docs — auto-generated plans, specs, audit snapshots
docs/superpowers/
docs/audit/gaps.md
docs/audit/probe-summary.md
docs/audit/integration-map.md

# Local reference docs — not for repo
SAYFA-ENVANTERI.md
SIRADAKI-SYSTEM-OVERVIEW.md

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Build artifacts
artifacts/
